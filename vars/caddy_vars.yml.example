# Caddy + Cloudflare Tunnel — MIGRATED TO VAULT
#
# Secrets are now stored in Vault at kv/homelab/data/caddy.
# Seed them once:
#   vault kv put kv/homelab/data/caddy \
#     cloudflare_api_token="..." \
#     cloudflare_tunnel_token="..." \
#     caddy_cloudflare_email="your-email@example.com"
#
# Then deploy with vault auth only:
#   ansible-playbook deployments/deploy_caddy.yml -e "@vars/vault_auth_vars.yml"
#
# This vars file is no longer needed.
