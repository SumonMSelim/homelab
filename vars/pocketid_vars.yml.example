# PocketID + Tinyauth — MIGRATED TO VAULT
#
# Secrets are now stored in Vault at kv/homelab/data/pocketid.
# Seed them once:
#   vault kv put kv/homelab/data/pocketid \
#     pocketid_encryption_key="$(openssl rand -base64 32)" \
#     tinyauth_pocketid_client_id="..." \
#     tinyauth_pocketid_client_secret="..." \
#     pocketid_maxmind_license_key=""
#
# Create the Tinyauth OIDC client at https://id.mol.la/settings/admin/oidc-clients
# Callback URL: https://id.mol.la/api/oauth/callback/pocketid
#
# Then deploy with vault auth only:
#   ansible-playbook deployments/deploy_pocketid.yml -e "@vars/vault_auth_vars.yml"
#
# This vars file is no longer needed.
